# =============================================================================
# IONOSPHERE — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your deployment.
# Lines starting with # are comments. Uncomment a line to override its default.

# --- CORE / REQUIRED ---

# Your Gemini API key (required)
GEMINI_API_KEY=your-api-key-here

# Bearer token clients must send in the Authorization header to use this server.
# If unset, all requests are accepted without auth.
API_KEY=your-server-auth-key-here

# HTTP port the server listens on (default: 3000)
PORT=3000

# Path to the Gemini CLI binary. Can be absolute or just the command name if
# it's on your PATH. (default: "gemini")
GEMINI_CLI_PATH=gemini

# Path to a .gemini/settings.json file that is copied into every workspace.
# Controls tool permissions, safety settings, etc. for the CLI. (default: ./settings.json)
GEMINI_SETTINGS_JSON=./settings.json

# Default model to use when the client doesn't specify one.
# Supports auto-fallback ladders (e.g. "gemini-2.5-pro" falls back to flash on quota errors).
# (default: gemini-2.5-flash-lite)
GEMINI_MODEL=gemini-2.5-flash-lite

# --- SERVER MODE ---

# "stateless" (default): Each request is independent; warm handoff reconnects
#   parked turns by matching conversation history hashes.
# "stateful": Reserved for future session-aware mode.
SESSION_MODE=stateless

# --- CONCURRENCY ---

# Maximum number of CLI processes running at the same time.
# Requests beyond this limit are queued FIFO. (default: 5)
MAX_CONCURRENT_CLI=5

# --- WARM STATELESS HANDOFF ---
# When the model emits a tool call, the CLI process stays alive ("parked")
# instead of exiting. The next HTTP request carrying the tool result hijacks
# the parked process and resumes it, avoiding a cold restart.

# Set to "false" to disable — every tool call kills the process and the next
# request starts a fresh CLI invocation. (default: true)
WARM_HANDOFF_ENABLED=true

# Number of pre-spawned CLI processes kept warm in the background, ready
# to serve the next request without cold-start latency. (default: 1)
# GEMINI_WARM_POOL_SIZE=1

# --- REPETITION BREAKER ---
# Detects and kills turns where the model enters repetition loops
# (echoing tool results, repeating reasoning blocks, etc.)

# Max identical consecutive tool calls before the turn is killed.
# 0 = unlimited (rely on other detection). (default: 0)
MAX_REPEAT_TOOL_CALLS=0

# Number of identical retries allowed before RepetitionBreaker escalates.
# Gives the model a few chances to self-correct. (default: 2)
REPEAT_GRACE_COUNT=2

# Set to "true" to disable all repetition detection (useful for stress tests). (default: false)
GEMINI_DISABLE_REPETITION_BREAKER=false

# Number of duplicate text blocks or summaries allowed before killing a turn. (default: 3)
REPETITION_THRESHOLD=3

# Max reasoning steps (thought chunks) allowed per turn before forced termination.
# Prevents runaway chain-of-thought loops. (default: 50)
MAX_REASONING_STEPS=50

# Character length of the sliding window used to detect repeated text blocks. (default: 200)
REPETITION_BLOCK_SIZE=200

# --- CLI PATCHING ---
# These are read by scripts/patch-gemini-core.js at build time, not at runtime.

# Strips tool declarations from the CLI's built-in prompt so the model can't
# self-invoke tools outside of Ionosphere's IPC protocol. (default: true)
GEMINI_DISABLE_TOOLS=true

# Applies additional safety patches to the CLI core (sandboxing, context limits). (default: true)
GEMINI_HARDENED=true

# Max tool-call turns the CLI is allowed in a single invocation. (default: 50)
# Read by setup scripts when generating the CLI config.
GEMINI_MAX_TURNS=50

# --- TIMEOUTS ---

# Absolute maximum time (ms) a single turn can run before forced termination.
# (default: 7200000 — 2 hours)
# TURN_TIMEOUT_MS=7200000

# Grace period (ms) after client disconnects before killing the turn.
# Gives the turn time to reach a parkable state for future hijacking. (default: 5000)
# DISCONNECT_GRACE_PERIOD_MS=5000

# Base timeout (ms) for CLI progress — if no stdout output arrives within this
# window, the process is killed as stalled. Actual timeout scales dynamically
# with prompt size using CLI_STALL_MS_PER_TOKEN. Floor: 60s, ceiling: 900s. (default: 60000)
CLI_STALL_TIMEOUT_MS=60000

# Linear scaling factor added to the stall timeout per estimated input token.
# Larger prompts need more time for context prefill before first output. (default: 1.5)
CLI_STALL_MS_PER_TOKEN=1.5

# --- GARBAGE COLLECTION ---

# Time-to-live (ms) for abandoned workspace directories in temp/.
# The GC sweeper runs every 5 minutes and deletes workspaces older than this
# that aren't associated with any active or parked turn. (default: 1800000 — 30 min)
GC_WORKSPACE_TTL_MS=3600000

# --- HISTORY FILTERING ---

# Strip all reasoning_content / thought / reasoning blocks from the
# OpenAI-format history before forwarding to Gemini. Reduces token usage
# but removes chain-of-thought context from the model's view. (default: false)
STRIP_REASONING=false

# When a model returns a quota/capacity error, suppress the error from the
# client response and silently retry with the next model in the fallback
# ladder. (default: false)
GEMINI_SILENT_FALLBACK=false

# --- PERFORMANCE INSTRUMENTATION ---

# Enable per-turn timing instrumentation (mark/measure for each phase).
# Logs timing breakdowns to console and optionally to a file. (default: false)
# GEMINI_PERF_TIMING=false

# Path to a JSONL file where perf timing records are appended.
# Only active when GEMINI_PERF_TIMING=true. If unset, timings are only
# logged to console and (when GEMINI_DEBUG_KEEP_TEMP=true) to the workspace.
# GEMINI_PERF_LOG=./perf.jsonl

# --- DEBUG FLAGS ---
# All default to "false". Enable selectively to diagnose specific subsystems.

# Retain temp workspace directories after turn completion. Also enables
# writing cli_raw_output.txt and cli_parsed_output.txt into each workspace.
GEMINI_DEBUG_KEEP_TEMP=false

# Write request.json and serialized_prompt.txt into each workspace for
# offline inspection of what was sent to the CLI.
GEMINI_DEBUG_PROMPTS=false

# Log SSE text/thought chunks as they are emitted to the client.
GEMINI_DEBUG_RESPONSES=false

# Log raw stdout chunks from the CLI before JSON parsing.
GEMINI_DEBUG_RAW=false

# Log IPC socket traffic (tool call events, result delivery, stall resets).
GEMINI_DEBUG_IPC=false

# Log the full OpenAI-format message array received in each request.
GEMINI_DEBUG_MESSAGES=false

# Log all hijack matching, handoff resolution, and parking decisions.
GEMINI_DEBUG_HANDOFF=false

# Log tool declaration filtering and historical tool tracking.
GEMINI_DEBUG_TOOLS=false

# Log extracted content blocks (text, images, tool results) during parsing.
GEMINI_DEBUG_CONTENT=false

# Log parallel tool call synchronization (stdout vs IPC race, debounce, etc.)
GEMINI_DEBUG_PARALLEL=false

# Log repetition detection forensics (hash comparisons, prompt tails, tracker state).
GEMINI_DEBUG_REPETITION=false

# --- SESSION CONTEXT OVERRIDES ---
# Spoof the environment details injected into the <session_context> block
# that the model sees. Useful for cross-platform or containerized deployments.

# Override the platform string (e.g. "linux", "macos", "windows")
# IONOSPHERE_PLATFORM=linux

# Override the temp directory path shown to the model
# IONOSPHERE_TEMP_DIR=/app/temp

# Override the current date string shown to the model
# IONOSPHERE_DATE="Monday, January 1, 2026"

# Override the directory listing context shown to the model
# IONOSPHERE_DIR_CONTEXT="[Spoofed Directory Structure]"

# Set to "true" to omit directory context entirely
# IONOSPHERE_DISABLE_DIR_CONTEXT=false
